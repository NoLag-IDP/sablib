local StealBtn, StealCircle = createToggle("Freeze victims screen", 122)
local AcceptBtn, AcceptCircle = createToggle("Auto accept trade", 168)

local function toggle(btn, circle, state)
    if state then
        TweenService:Create(circle, TweenInfo.new(0.2), {
            Position = UDim2.new(1, -22, 0.5, -10)
        }):Play()
        TweenService:Create(btn, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        }):Play()
    else
        TweenService:Create(circle, TweenInfo.new(0.2), {
            Position = UDim2.new(0, 2, 0.5, -10)
        }):Play()
        TweenService:Create(btn, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(70, 70, 80)
        }):Play()
    end
end

