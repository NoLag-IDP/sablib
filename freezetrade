-- =====================================================
-- GLOBAL USERNAME LOOKUP
-- =====================================================

local function resetProfile()
    ProfilePic.Image = ""
    StatusIndicator.Text = "?"
    StatusIndicator.TextColor3 = Color3.fromRGB(150, 150, 160)
    StatusIndicator.Visible = true
    targetUserId = nil
    targetUsername = ""

    if stealEnabled then
        stealEnabled = false
        toggle(StealBtn, StealCircle, false)
    end
    if acceptEnabled then
        acceptEnabled = false
        toggle(AcceptBtn, AcceptCircle, false)
    end
end

local function lookupUsername(username)
    if username == "" then
        resetProfile()
        return
    end

    StatusIndicator.Text = "..."
    StatusIndicator.TextColor3 = Color3.fromRGB(200, 200, 100)
    StatusIndicator.Visible = true
    ProfilePic.Image = ""

    task.spawn(function()
        local success, userId = pcall(function()
            return Players:GetUserIdFromNameAsync(username)
        end)

        if UsernameBox.Text:lower() ~= username:lower() then return end

        if success and userId then
            targetUserId = userId
            targetUsername = username
            ProfilePic.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId .. "&width=150&height=150&format=png"
            StatusIndicator.Visible = false
        else
            resetProfile()
            StatusIndicator.Text = "✗"
            StatusIndicator.TextColor3 = Color3.fromRGB(220, 80, 80)
            StatusIndicator.Visible = true
        end
    end)
end

local lastText = ""
UsernameBox:GetPropertyChangedSignal("Text"):Connect(function()
    local current = UsernameBox.Text
    lastText = current

    if current == "" then
        resetProfile()
        return
    end

    task.delay(0.6, function()
        if UsernameBox.Text == current then
            lookupUsername(current)
        end
    end)
end)

